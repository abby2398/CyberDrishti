# ─────────────────────────────────────────────────────
#  CyberDrishti — .env
#  KEEP THIS FILE PRIVATE. Never commit to Git.
# ─────────────────────────────────────────────────────

# ── Project ───────────────────────────────────────────
PROJECT_NAME=CyberDrishti
VERSION=1.0.0
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────
DB_PASSWORD=CyberDrishti2026
DATABASE_URL=postgresql://drishti:CyberDrishti2026@db:5432/cyberdrishti

# ── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=RedisDrishti2026
REDIS_URL=redis://:RedisDrishti2026@redis:6379/0

# ── Security ──────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_secret_key_before_production
API_KEY=changeme_generate_a_real_api_key_for_dashboard_access

# ── Scanner Settings ──────────────────────────────────
SCAN_RATE_LIMIT=5           # Max requests per second per domain (DO NOT increase)
SCAN_TIMEOUT=10             # HTTP timeout in seconds
SCAN_MAX_RETRIES=3          # Retries on connection failure
SCAN_CONCURRENCY=4          # Celery worker threads

# ── External APIs (fill in after procurement) ─────────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
WHOIS_XML_API_KEY=
HIBP_API_KEY=
INTELX_API_KEY=

# ── Email (Disclosure notifications) ─────────────────
# Use SMTP of your choice (Gmail, Outlook, CERT-IN SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DISCLOSURE_FROM_EMAIL=disclosures@cyberdrishti.certIn.gov.in

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/cyberdrishti.log
